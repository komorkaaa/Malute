<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:top="2dp"
        android:right="1dp"
        android:bottom="0dp">
        <shape android:shape="oval">
            <size
                android:width="28dp"
                android:height="28dp" />
            <solid android:color="#18000000" />
        </shape>
    </item>

    <item android:bottom="2dp">
        <shape android:shape="oval">
            <size
                android:width="28dp"
                android:height="28dp" />
            <solid android:color="@color/white" />
            <stroke
                android:width="1.5dp"
                android:color="#2C73EA" />
        </shape>
    </item>
</layer-list>
